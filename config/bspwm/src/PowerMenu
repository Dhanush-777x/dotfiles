#!/usr/bin/env bash

options=(
    "пЂЈ"
    "п††"
    "пњ…"
    "пѓў"
    "пЂ‘"
)

rofi_cmd() {
	rofi -dmenu \
		-p "Goodbye ${USER}" \
		-mesg "Uptime: $(uptime -p | sed -e 's/up //g')" \
		-theme "$HOME"/.config/bspwm/src/rofi-themes/PowerMenu.rasi
}

chosen=$(printf "%s\n" "${options[@]}" | rofi_cmd)

case $chosen in
    "пЂ‘")
        systemctl poweroff
        ;;
    "пѓў")
        systemctl reboot
        ;;
    "пЂЈ")
        betterlockscreen -l blur
        ;;
    "п††")
        mpc -q pause
        amixer set Master mute
        systemctl suspend
        ;;
    "пњ…")
        bspc quit
        ;;
esac
